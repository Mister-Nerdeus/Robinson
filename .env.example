# Runtime
APP_PORT=4850
LOCAL_ONLY_MODE=true
ENABLE_PRODUCTION_DEPLOY=false

# Admin/local review
ENABLE_ADMIN_SUBMISSIONS_REVIEW=false

# Notifications
NOTIFICATION_MODE=log
NOTIFICATION_TO_EMAIL=service@robinsonseptic.com
NOTIFICATION_FROM_EMAIL=no-reply@robinsonseptic.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Abuse controls
RATE_LIMIT_MAX=8
RATE_LIMIT_WINDOW_MS=900000

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=internal
